#!/usr/bin/env bash
# SeamOS Everywhere — SessionStart hook
#
# Emits a short routing compass on stdout when the current working directory
# (or an ancestor) looks like a SeamOS workspace. Claude Code captures the
# stdout and injects it into the conversation as SessionStart additional
# context — effectively a session-scoped CLAUDE.md without writing any file
# to the user's repo.
#
# Workspace detection (walks up to 8 levels from CWD):
#   - .seamos-workspace.json present
#   - seamos-assets/ directory present
#   - .mcp.json mentions "seamos-marketplace" or "seamos-docs"
#
# Non-SeamOS sessions: exit 0 with no output (zero token cost).

set -eo pipefail

# Drain hook stdin — Claude Code sends a JSON event we don't need.
cat >/dev/null 2>&1 || true

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
COMPASS="${PLUGIN_ROOT}/hooks/compass.md"

DIR="$(pwd)"
HIT=0
for _ in 1 2 3 4 5 6 7 8; do
  if [ -f "$DIR/.seamos-workspace.json" ] || [ -d "$DIR/seamos-assets" ]; then
    HIT=1
    break
  fi
  if [ -f "$DIR/.mcp.json" ] && grep -q -E '"(seamos-marketplace|seamos-docs)"' "$DIR/.mcp.json" 2>/dev/null; then
    HIT=1
    break
  fi
  PARENT="$(dirname "$DIR")"
  [ "$PARENT" = "$DIR" ] && break
  DIR="$PARENT"
done

[ "$HIT" -eq 0 ] && exit 0
[ -f "$COMPASS" ] && cat "$COMPASS"
exit 0
