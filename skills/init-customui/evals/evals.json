    "input": {
      "command": "bash",
      "args": [
        "skills/init-customui/scripts/init-customui.sh",
        "--ui",
        "vanilla",
        "--non-interactive",
        "--dry-run"
      ],
      "cwd": "/tmp/icu-eval-vfresh",
      "setup": {
        "fixtures": [
          { "type": "mkdir", "path": "/tmp/icu-eval-vfresh/MyProj/MyProj/MyProj_App/ui" },
          {
            "type": "write",
            "path": "/tmp/icu-eval-vfresh/.seamos-workspace.json",
            "content": "{\n  \"schemaVersion\": 1,\n  \"createdAt\": \"2026-05-06T00:00:00Z\",\n  \"scope\": \"project\",\n  \"ui\": {\n    \"defaultFramework\": null,\n    \"activeSrcPath\": null,\n    \"react\": {\n      \"templateRepo\": \"https://github.com/AGMO-Inc/custom-ui-react-template\",\n      \"templateRef\": \"master\"\n    }\n  },\n  \"marketplace\": {\n    \"endpoint\": \"dev\",\n    \"endpointUrl\": \"https://dev.marketplace-api.seamos.io/mcp\"\n  }\n}\n"
          },
          {
            "type": "write",
            "path": "/tmp/icu-eval-vfresh/.seamos-context.json",
            "content": "{\n  \"last_project\": {\n    \"name\": \"MyProj\",\n    \"app_project_name\": \"MyProj_App\",\n    \"app_project_path\": \"/tmp/icu-eval-vfresh/MyProj/MyProj/MyProj_App\"\n  }\n}\n"
          }
        ]
      }
    },
    "expected": {
      "exit_code": 0,
      "stdout_contains": [
        "STATUS_OK",
        "[dry-run]",
        "vanilla"
      ],
      "stderr_contains": []
    },
    "timeout_ms": 10000
  },
