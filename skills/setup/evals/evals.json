[
  {
    "name": "setup_project_scope_fresh",
    "description": "Fresh project-scope bootstrap with --dry-run prints planned writes and STATUS_OK without mutating the workspace.",
    "input": {
      "command": "bash",
      "args": [
        "skills/setup/scripts/setup.sh",
        "--workspace-dir",
        "/tmp/setup-eval-fresh",
        "--endpoint",
        "dev",
        "--non-interactive",
        "--dry-run"
      ],
      "setup": {
        "fixtures": [
          { "type": "mkdir", "path": "/tmp/setup-eval-fresh" }
        ]
      }
    },
    "expected": {
      "exit_code": 0,
      "stdout_contains": [
        "STATUS_OK",
        "seamos-marketplace",
        "[dry-run]"
      ],
      "stderr_contains": []
    },
    "timeout_ms": 10000
  },
  {
    "name": "setup_project_scope_idempotent",
    "description": "Second run with identical args after a successful first run reports [skip] for existing files and exits 0.",
    "input": {
      "command": "bash",
      "args": [
        "skills/setup/scripts/setup.sh",
        "--workspace-dir",
        "/tmp/setup-eval-idem",
        "--endpoint",
        "dev",
        "--non-interactive"
      ],
      "setup": {
        "fixtures": [
          { "type": "mkdir", "path": "/tmp/setup-eval-idem" },
          { "type": "mkdir", "path": "/tmp/setup-eval-idem/seamos-assets/builds" },
          { "type": "mkdir", "path": "/tmp/setup-eval-idem/seamos-assets/screenshots" },
          {
            "type": "write",
            "path": "/tmp/setup-eval-idem/.seamos-workspace.json",
            "content": "{\n  \"schemaVersion\": 1,\n  \"createdAt\": \"2026-05-06T00:00:00Z\",\n  \"scope\": \"project\",\n  \"ui\": {\n    \"defaultFramework\": null,\n    \"activeSrcPath\": null,\n    \"react\": {\n      \"templateRepo\": \"https://github.com/AGMO-Inc/custom-ui-react-template\",\n      \"templateRef\": \"main\"\n    }\n  },\n  \"marketplace\": {\n    \"endpoint\": \"dev\",\n    \"endpointUrl\": \"https://dev.marketplace-api.seamos.io/mcp\"\n  }\n}\n"
          },
          {
            "type": "write",
            "path": "/tmp/setup-eval-idem/.mcp.json",
            "content": "{\n  \"mcpServers\": {\n    \"seamos-marketplace\": {\n      \"type\": \"stdio\",\n      \"command\": \"npx\",\n      \"args\": [\n        \"mcp-remote\",\n        \"https://dev.marketplace-api.seamos.io/mcp\"\n      ]\n    }\n  }\n}\n"
          }
        ]
      }
    },
    "expected": {
      "exit_code": 0,
      "stdout_contains": [
        "STATUS_OK",
        "[skip]"
      ],
      "stderr_contains": []
    },
    "timeout_ms": 10000
  },
  {
    "name": "setup_user_scope_no_mcp_write",
    "description": "When invoked through a wrapper under ~/.claude/plugins/, scope resolves to user and .mcp.json must not be written.",
    "input": {
      "command": "bash",
      "args": [
        "/tmp/setup-eval-userscope/.claude/plugins/fake-plugin/scripts/setup.sh",
        "--workspace-dir",
        "/tmp/setup-eval-userscope",
        "--endpoint",
        "dev",
        "--non-interactive"
      ],
      "setup": {
        "fixtures": [
          { "type": "mkdir", "path": "/tmp/setup-eval-userscope" },
          { "type": "mkdir", "path": "/tmp/setup-eval-userscope/.claude/plugins/fake-plugin/scripts" },
          {
            "type": "write",
            "path": "/tmp/setup-eval-userscope/.claude/plugins/fake-plugin/scripts/setup.sh",
            "content": "#!/usr/bin/env bash\nset -euo pipefail\nexec bash \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/skills/setup/scripts/setup.sh\" \"$@\"\n"
          }
        ]
      }
    },
    "expected": {
      "exit_code": 0,
      "stdout_contains": [
        "STATUS_OK",
        "[user-scope] skipping .mcp.json",
        "\"scope\": \"user\""
      ],
      "stderr_contains": []
    },
    "timeout_ms": 10000
  },
  {
