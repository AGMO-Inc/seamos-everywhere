            "content": "{\n  \"mcpServers\": {\n    \"seamos-marketplace\": {\n      \"type\": \"stdio\",\n      \"command\": \"npx\",\n      \"args\": [\n        \"mcp-remote\",\n        \"http://localhost:8088/mcp\"\n      ]\n    }\n  }\n}\n"
